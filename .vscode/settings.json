{
    // --- Python & Pyrefly ---
    "python.languageServer": "Default",
    "python.pyrefly.typeCheckingMode": "default",
    "python.pyrefly.disableTypeErrors": false,
    "python.autoComplete.extraPaths": [
        "/opt/ros/jazzy/lib/python3.12/site-packages",
        "/root/ros2_ws/install/ros2_interfaces/lib/python3.12/site-packages"
    ],
    "python.REPL.enableREPLSmartSend": false,
    // --- C++ & Clangd ---
    "C_Cpp.intelliSenseEngine": "disabled",
    "clangd.arguments": [
        "--compile-commands-dir=${workspaceFolder}/build",
        "--header-insertion=never",
        "--all-scopes-completion",
        "--completion-style=detailed"
    ],
    // --- ROS 2 Specifics ---
    "ROS2.distro": "jazzy",
    "cmake.ignoreCMakeListsMissing": true,
    // --- Performance & UI ---
    "explorer.confirmDelete": false,
    "git.autofetch": true,
    "files.exclude": {
        "**/build": true,
        "**/install": true,
        "**/log": true,
        "**/__pycache__": true
    },
    "search.exclude": {
        "**/build": true,
        "**/install": true,
        "**/log": true
    },
    // --- URDF Visualizer ---
    "urdf-visualizer.packages": {
        "core_description": "${workspaceFolder}/src/gazebo_sim/gazebo_core/core_description"
    }
}